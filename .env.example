# PostgreSQL
POSTGRES_DB=date_planner
POSTGRES_USER=date_planner
POSTGRES_PASSWORD=date_planner_dev_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Published development ports
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Django
# Replace this development-only value in every non-local environment.
DJANGO_SECRET_KEY=dev-only-change-me-before-deploying
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Nuxt (this public URL is used by the browser)
NUXT_PUBLIC_API_BASE_URL=http://localhost:8000
